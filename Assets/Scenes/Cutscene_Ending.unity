  dialogueText: {fileID: 1063430546}
  dialogues:
  - speaker: Unknown
    text: You did it.
  - speaker: Player
    text: Is this the end? Who are you?
  - speaker: Unknown
    text: ...
  - speaker: Player
    text: Well...
  - speaker: Player
    text: I've been through 12 locations.
  - speaker: Player
    text: I've encountered various challenges along the way...
  - speaker: Player
    text: Enemies, obstacles, lack of time...
  - speaker: Player
    text: But I realized something...
  - speaker: Player
    text: Speed, risk, and difficulty are things I love and have lacked in the past.
  nextScene: MainMenu
